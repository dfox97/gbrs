---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import ProjectCard from '../../components/ProjectCard.astro';
import PageHero from '../../components/PageHero.astro';
import { SERVICES, projectMatchesService, getServiceBySlug, type ProjectCategoryKey } from '../../consts';

// Generate all service pages at build time
export async function getStaticPaths() {
  return SERVICES.map(service => ({
    params: { service: service.slug },
    props: { service }
  }));
}

interface Props {
  service: typeof SERVICES[0];
}

const { service } = Astro.props;

// Get all projects and filter by service
const allProjects = await getCollection('projects');
const filteredProjects = allProjects.filter(project => 
  projectMatchesService(project.data, service)
);

// Sort by order
const sortedProjects = filteredProjects.sort((a, b) => a.data.order - b.data.order);
---

<Layout 
  title={service.metaTitle}
  description={service.metaDescription}
  activePage="services"
>
  <PageHero 
    title={service.title} 
    subtitle={service.subtitle}
  >
    <div style="margin-top: 20px;">
      <a href="/services" class="btn-secondary" style="background: rgba(255,255,255,0.2); border-color: white;">← Back to Services</a>
    </div>
  </PageHero>

  <section class="projects section">
    <div class="container">
      <div class="section-header">
        <h2>{service.title} Projects</h2>
      </div>
      <p class="projects-intro">
        {service.introText}
      </p>
      
      <div class="projects-grid-enhanced">
        {sortedProjects.map(project => (
          <ProjectCard project={project} />
        ))}

        {sortedProjects.length === 0 && (
          <div class="project-card" style="grid-column: 1 / -1; background: var(--light-grey); text-align: center; padding: 60px 20px;">
            <h3 style="margin-bottom: 15px; color: #333;">Projects Coming Soon</h3>
            <p style="margin-bottom: 25px; color: #666;">We're currently uploading our {service.title.toLowerCase()} projects. Check back soon or contact us to discuss your requirements.</p>
            <a href="/#contact" class="btn-primary">Get a Free Quote</a>
          </div>
        )}

        {sortedProjects.length > 0 && (
          <div class="project-card" style="grid-column: 1 / -1; background: var(--light-grey); text-align: center; padding: 60px 20px;">
            <h3 style="margin-bottom: 15px; color: #333;">More Projects Coming Soon</h3>
            <p style="margin-bottom: 25px; color: #666;">We're currently updating our portfolio with 120+ completed projects. Check back soon or contact us to discuss your requirements.</p>
            <a href="/#contact" class="btn-primary">Get a Free Quote</a>
          </div>
        )}
      </div>
    </div>
  </section>
</Layout>
